{
  "mcpServers": {
    "postgres": {
      "type": "stdio",
      "command": "/bin/sh",
      "args": [
        "-c",
        "PGPASSWORD=$DB_CLAUDE_PASSWORD npx -y @modelcontextprotocol/server-postgres postgresql://claude@hetzner:5432/trading"
      ],
      "env": {
        "DB_CLAUDE_PASSWORD": "${DB_CLAUDE_PASSWORD}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--user-data-dir=./.playwright-profile"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/jack/github/turtle-backtest"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
